{
	"name": "samizdata",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "pnpm copy:training-assets",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"copy:training-assets": "pwsh -NoProfile -Command \"New-Item -ItemType Directory -Force -Path 'static/training/media' | Out-Null\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "1.8.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"mdsvex": "^0.12.7",
		"prismjs": "^1.30.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"sveltekit-i18n": "^2.4.2"
	}
}
