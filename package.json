{
	"name": "samizdata",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "npm run fetch-rss && vite build",
		"fetch-rss": "node scripts/fetch-rss.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
